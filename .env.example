# ── Server ─────────────────────────────────────────────
PORT=8080

# Comma-separated list of API keys that clients must send to use the gateway.
# Clients authenticate via the "Authorization: Bearer <key>" header.
# Leave empty to disable gateway auth (NOT recommended outside local dev).
GATEWAY_API_KEYS=demo-key-123

# ── Providers ──────────────────────────────────────────
# Order in which providers are tried. The first one is primary,
# the rest are fallbacks (used when the previous one fails).
# Available: mock, openai, anthropic, gemini
PROVIDER_ORDER=mock

# Real provider credentials (only needed if you use them in PROVIDER_ORDER)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1

# Google Gemini (has a free tier — get a key at https://aistudio.google.com/apikey)
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai

# ── Cache ──────────────────────────────────────────────
CACHE_ENABLED=true
CACHE_TTL_SECONDS=300
CACHE_MAX_ENTRIES=500

# ── Rate limit (per gateway API key) ───────────────────
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=30

# ── Logging ────────────────────────────────────────────
LOG_TO_FILE=true
LOG_DIR=logs

# ── Reliability ────────────────────────────────────────
# Abort a provider call that exceeds this many ms.
REQUEST_TIMEOUT_MS=30000
# Retries of the SAME provider on transient errors (429/5xx/timeout)
# before falling back to the next provider.
RETRY_MAX=2
RETRY_BASE_MS=300
# Circuit breaker: open after N consecutive failures, stay open for cooldown.
CIRCUIT_FAILURE_THRESHOLD=5
CIRCUIT_COOLDOWN_SECONDS=30
