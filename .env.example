# ── Server ─────────────────────────────────────────────
PORT=8080

# Comma-separated list of API keys that clients must send to use the gateway.
# Clients authenticate via the "Authorization: Bearer <key>" header.
# Leave empty to disable gateway auth (NOT recommended outside local dev).
GATEWAY_API_KEYS=demo-key-123

# ── Providers ──────────────────────────────────────────
# Order in which providers are tried. The first one is primary,
# the rest are fallbacks (used when the previous one fails).
# Available: mock, openai, anthropic, gemini
PROVIDER_ORDER=mock

# Routing strategy for same-tier targets defined in routes.json:
#   tier    — weighted round-robin load balancing (default)
#   latency — prefer the fastest-responding target (EWMA)
ROUTING_STRATEGY=tier

# Real provider credentials (only needed if you use them in PROVIDER_ORDER).
# Each accepts MULTIPLE comma-separated keys — the gateway rotates across them
# and rests any key that returns 429, so you can pool quota across accounts.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1

# Google Gemini (has a free tier — get a key at https://aistudio.google.com/apikey)
# Multiple keys allowed: GEMINI_API_KEY=key1,key2,key3
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai

# How long (seconds) to rest an API key after it returns 429.
KEY_COOLDOWN_SECONDS=60

# ── Cache ──────────────────────────────────────────────
CACHE_ENABLED=true
CACHE_TTL_SECONDS=300
CACHE_MAX_ENTRIES=500

# ── Rate limit (per gateway API key) ───────────────────
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=30

# ── Token saver (reduce input tokens) ──────────────────
# Trim conversation history + whitespace before calling the provider.
TOKEN_SAVER_ENABLED=false
# Keep at most N most-recent non-system messages (unset = no cap).
TOKEN_SAVER_MAX_MESSAGES=12
# Drop oldest messages until estimated input tokens fit (unset = off).
# TOKEN_SAVER_MAX_INPUT_TOKENS=4000
TOKEN_SAVER_TRIM_WHITESPACE=true

# ── Logging ────────────────────────────────────────────
LOG_TO_FILE=true
LOG_DIR=logs

# ── Per-key budget / quota ─────────────────────────────
# Enforce daily request count + cost budget per API key.
# Per-key overrides live in budgets.json; these are the defaults.
# Leave unset for "unlimited".
BUDGET_ENABLED=true
DEFAULT_DAILY_REQUESTS=1000
DEFAULT_DAILY_COST_USD=1.0

# ── Reliability ────────────────────────────────────────
# Abort a provider call that exceeds this many ms.
REQUEST_TIMEOUT_MS=30000
# Retries of the SAME provider on transient errors (429/5xx/timeout)
# before falling back to the next provider.
RETRY_MAX=2
RETRY_BASE_MS=300
# Circuit breaker: open after N consecutive failures, stay open for cooldown.
CIRCUIT_FAILURE_THRESHOLD=5
CIRCUIT_COOLDOWN_SECONDS=30
